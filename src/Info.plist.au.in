<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Custom AU Info.plist so the AudioComponent shows "Pulp: GPU NAM" (not the
     generated template's "Pulp: GpuNam"). Version fields are substituted from
     GPU_NAM_VERSION at configure time so they can never drift from the project
     version — see src/CMakeLists.txt. -->
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>GpuNam</string>
    <key>CFBundleIdentifier</key>
    <string>com.pulp.gpunam.au</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>GpuNam</string>
    <key>CFBundlePackageType</key>
    <string>BNDL</string>
    <key>CFBundleShortVersionString</key>
    <string>@GPU_NAM_VERSION@</string>
    <key>CFBundleVersion</key>
    <string>@GPU_NAM_VERSION@</string>
    <key>AudioComponents</key>
    <array>
        <dict>
            <key>name</key>
            <string>Pulp: GPU NAM</string>
            <key>description</key>
            <string>GPU NAM Neural Amp Modeler</string>
            <key>manufacturer</key>
            <string>Pulp</string>
            <key>type</key>
            <string>aufx</string>
            <key>subtype</key>
            <string>GNam</string>
            <key>version</key>
            <integer>@GPU_NAM_AU_VERSION_INT@</integer>
            <key>factoryFunction</key>
            <string>GpuNamAUFactory</string>
            <key>sandboxSafe</key>
            <true/>
        </dict>
    </array>
</dict>
</plist>
